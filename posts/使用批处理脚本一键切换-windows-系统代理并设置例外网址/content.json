    {
      "type": "heading",
      "attrs": {
        "id": "完整脚本代码",
        "data-toc-id": "完整脚本代码",
        "level": 2
      },
      "content": [
        {
          "type": "text",
          "marks": [
            {
              "type": "bold"
            }
          ],
          "text": "完整脚本代码"
        }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        {
          "type": "text",
          "text": "将以下内容保存为 "
        },
        {
          "type": "text",
          "marks": [
            {
              "type": "code"
            }
          ],
          "text": "toggle_proxy.bat"
        },
        {
          "type": "text",
          "text": "，"
        },
        {
          "type": "text",
          "marks": [
            {
              "type": "bold"
            }
          ],
          "text": "以 ANSI 编码"
        },
        {
          "type": "text",
          "text": "保存（否则中文可能乱码）。"
        }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        {
          "type": "text",
          "text": "batch"
        }
      ]
    },
    {
      "type": "codeBlock",
      "attrs": {
        "language": "shell",
        "highlightedHtml": null
      },
      "content": [
        {
          "type": "text",
          "text": "@echo off\nsetlocal enabledelayedexpansion\n\n:: ========== 请在这里修改你的配置 ==========\nset \"ProxyServerAddr=127.0.0.1:7890\"\nset \"excludeSites=localhost;127.0.0.1;<local>;*.example.com\"\n:: =========================================\n\nfor /f \"tokens=1,2,* \" %%i in ('REG QUERY \"HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\Internet Settings\" /v ProxyEnable ^| find /i \"ProxyEnable\"') do (set /A ProxyEnableValue=%%k)\n\nif %ProxyEnableValue% equ 0 (\n    echo 系统代理目前处于关闭状态，正在开启代理，请稍候...\n    echo=\n    reg add \"HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\Internet Settings\" /v ProxyEnable /t REG_DWORD /d 1 /f >nul 2>nul\n    reg add \"HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\Internet Settings\" /v ProxyServer /d \"%ProxyServerAddr%\" /f >nul 2>nul\n    reg add \"HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\Internet Settings\" /v ProxyOverride /d \"%excludeSites%\" /f >nul 2>nul\n    echo 系统代理已开启，代理地址：%ProxyServerAddr%\n    echo 例外网址：%excludeSites%\n    echo 请按任意键关闭本窗口...\n) else if %ProxyEnableValue% equ 1 (\n    echo 系统代理目前处于开启状态，正在关闭代理，请稍候...\n    echo=\n    reg add \"HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\Internet Settings\" /v ProxyEnable /t REG_DWORD /d 0 /f >nul 2>nul\n    reg add \"HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\Internet Settings\" /v ProxyServer /d \"\" /f >nul 2>nul\n    :: 下方命令可选：关闭代理时是否清空例外列表（默认不清空，如需清空请取消注释）\n    :: reg add \"HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\Internet Settings\" /v ProxyOverride /d \"\" /f >nul 2>nul\n    echo 系统代理已关闭\n    echo 请按任意键退出本窗口...\n)\n\npause >nul"
        }
      ]
    },
    {
      "type": "horizontalRule"
    },
