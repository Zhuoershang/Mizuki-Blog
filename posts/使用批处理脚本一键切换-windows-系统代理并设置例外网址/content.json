            }
          ]
        },
        {
          "type": "listItem",
          "content": [
            {
              "type": "paragraph",
              "content": [
                {
                  "type": "text",
                  "text": "✅ 关闭代理时恢复干净网络环境"
                }
              ]
            }
          ]
        },
        {
          "type": "listItem",
          "content": [
