                        {
                          "type": "text",
                          "text": "​Authorization: Bearer 你的Worker API密钥​"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "listItem",
                  "content": [
                    {
                      "type": "paragraph",
                      "content": [
                        {
                          "type": "text",
                          "text": "​Content-Type: application/javascript​"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "listItem",
          "content": [
            {
              "type": "paragraph",
              "content": [
                {
                  "type": "text",
                  "text": "接口调用成功包含的字符串：\"success\": true​"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "blockquote",
      "content": [
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "📌 账户ID可以在Cloudflare控制台右侧栏找到。"
            }
          ]
        }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        {
          "type": "text",
          "text": "请求体（注意targetPort​字段使用了#{port}​变量，lucky会自动替换为STUN获取的公网端口）："
        }
      ]
    },
    {
      "type": "codeBlock",
      "attrs": {
        "language": "javascript",
        "highlightedHtml": null
      },
      "content": [
        {
          "type": "text",
          "text": "// 配置参数\nconst CONFIG = {\n    // 需要重定向的域名\n    sourceDomain: 'a.com',\n    // 重定向后的域名\n    targetDomain: 'b.net',\n    // 目标端口号 - #{port}会被lucky自动替换为STUN获取的公网端口\n    targetPort: '#{port}'\n};\n\naddEventListener('fetch', event => {\n    event.respondWith(handleRequest(event.request));\n});\n\nasync function handleRequest(request) {\n    const url = new URL(request.url);\n    const hostname = url.hostname;\n\n    // 只要hostname中包含sourceDomain，就将sourceDomain替换为targetDomain，并指定port\n    if (hostname.includes(CONFIG.sourceDomain)) {\n        const newHost = hostname.replace(CONFIG.sourceDomain, CONFIG.targetDomain);\n        const targetUrl = `https://${newHost}:${CONFIG.targetPort}${url.pathname}${url.search}`;\n\n        // 返回302临时重定向\n        return Response.redirect(targetUrl, 302);\n    }\n    // 如果不是目标域名，则返回404\n    return new Response('Not Found', { status: 404 });\n}\n"
        }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        {
          "type": "text",
          "text": "配置完成后，每当STUN穿透获取到新的公网端口，lucky会自动调用WebHook更新Worker脚本中的端口号，实现端口的动态更新。"
        }
      ]
    },
