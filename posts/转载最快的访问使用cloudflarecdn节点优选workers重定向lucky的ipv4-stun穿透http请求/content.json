                    }
                  ],
                  "text": "https://api.cloudflare.com/client/v4/accounts/你的账户ID/workers/scripts/redirect​"
                }
              ]
            }
          ]
        },
        {
          "type": "listItem",
          "content": [
            {
              "type": "paragraph",
              "content": [
                {
                  "type": "text",
                  "text": "请求方法：PUT​"
                }
              ]
            }
          ]
        },
        {
          "type": "listItem",
          "content": [
            {
              "type": "paragraph",
              "content": [
                {
                  "type": "text",
                  "text": "请求头："
                }
              ]
            },
            {
              "type": "bulletList",
              "content": [
